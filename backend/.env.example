DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.7
MAX_HISTORY_MESSAGES=24
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CHATBOT_SYSTEM_PROMPT=You are a helpful, concise chatbot. Answer in the user's language.
RAG_STORAGE_DIR=storage
ZHIPU_EMBEDDING_MODEL=embedding-3
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4

# LangSmith (optional — Copilot + Chat tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=agentic-ai-copilot
LANGSMITH_EVAL_DATASET=copilot-tool-routing-golden
